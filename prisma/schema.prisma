// This is your Prisma schema file,
// learn more about it in docs: https://pris.ly/d/auth-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql" // Make sure your env uses the Neon URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// CORE & AUTH (Standard NextAuth configuration)
// -----------------------------------------------------------------------------

model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  name               String?
  emailVerified      DateTime?
  image              String?
  companyName        String?
  abn                String?
  ndisProviderNumber String?
  businessAddress    String?
  contactPhone       String?
  logoUrl            String?  // White-label branding logo (Azure blob URL)
  website            String?
  language           String           @default("en-AU") // English AU native.
  timezone           String           @default("Australia/Sydney")
  dataRegion         String           @default("ap-southeast-2")
  complianceScore    Float            @default(100.0)
  stripeCustomerId   String?          @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  accounts           Account[]
  sessions           Session[]
  subscription       Subscription?
  teamMembers        TeamMember[]
  chatbots           Chatbot[]
  analyses           Analysis[]
  analysisTasks      AnalysisTask[]
  auditLogsActed     AuditLog[]      // Actions performed BY this user
  claims             Claim[]
  xeroToken          XeroToken?

  @@index([email])
}

model Account {
  id                 String     @id @default(cuid())
  userId             String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// SUBSCRIPTION & BILLING
// -----------------------------------------------------------------------------

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planType             String    @default("free")
  status               String    @default("active")
  currentPeriodStart   DateTime  @default(now())
  currentPeriodEnd     DateTime?
  maxChatbots          Int       @default(1)
  hasAdvancedAnalytics Boolean   @default(false)
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// AI COMPLIANCE ENGINE (CHATBOTS)
// -----------------------------------------------------------------------------

model Chatbot {
  id                 String         @id @default(cuid())
  userId             String
  name               String         // E.g., "NDIS Support Bot"
  identifier         String         @unique // Public URL slug
  customDomain       String?        @unique // e.g. chat.company.com
  primaryColor       String         @default("#0f766e")
  widgetPrimaryColor String         @default("#0f766e")
  widgetButtonColor  String         @default("#0f766e")
  botName            String         @default("AI Assistant")
  welcomeMessage     String         @default("Welcome. How can we assist with your NDIS plan today?")
  fallbackMessage    String         @default("I cannot process that request. Let me connect you with a coordinator.")
  language           String         @default("en") // Default
  aiModel            String         @default("gpt-4-turbo-preview") // Better accuracy for audits
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  documents          Document[]
  leads              Lead[]

  @@index([userId])
}

model Document {
  id           String          @id @default(cuid())
  chatbotId    String
  name         String          // e.g. "Pricing_Arrangements_2026.pdf"
  type         String
  url          String?
  status       String          @default("processing")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  chatbot      Chatbot         @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]

  @@index([chatbotId])
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  content    String
  chunkIndex Int
  createdAt  DateTime @default(now())
  // embedding Unsupported("vector")? // Uncomment once PgVector is fully setup
  
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// NDIS COMPLIANCE ANALYSES (DOCUMENT VAULT)
// -----------------------------------------------------------------------------

model Analysis {
  id              String   @id @default(cuid())
  userId          String
  fileName        String
  participantName String?  // Extracted from document automatically
  complianceScore Float    @default(0.0)
  warnings        Json     // Stores array of warning objects/strings
  remediationText Json?    // Stores the Key-Value AI generated fixes
  pdfUrl          String?  // Supabase bucket sovereign storage link
  documentStartDate String? 
  documentEndDate   String? 
  region          String   @default("ap-southeast-2") // Sovereignty proof
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisTasks   AnalysisTask[]

  @@index([userId])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// BULK ANALYSIS QUEUE
// -----------------------------------------------------------------------------

model AnalysisTask {
  id              String    @id @default(cuid())
  userId          String
  fileName        String
  participantName  String?
  documentStartDate String?
  documentEndDate   String?
  complianceScore  Float?
  addendumFileUrl  String?
  status          String    @default("pending") // pending, processing, completed, failed
  fileUrl         String?   // Azure Blob Storage link
  analysisId      String?   @unique // Link to Analysis when completed
  resultJson      Json?     // Full AI analysis response (warnings, score, suggestions)
  approvedBy      String?   // Name of the human approver
  approverTitle   String?   // Title/role of the approver
  approvalDate    DateTime? // Timestamp of the human approval
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis        Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// CONVERSATIONS & LEADS (THE AUDIT DATA)
// -----------------------------------------------------------------------------

model Conversation {
  id               String                @id @default(cuid())
  chatbotId        String
  visitorId        String                // Anonymous tracking until verified
  status           String                @default("active")
  
  // -- NDIS AUDIT CORE FIELDS --
  originalLanguage String?               // ISO code of patient language
  translatedText   Json?                 // Translated log to English for auditors
  isSensitive      Boolean               @default(false) // Flag for PHI
  auditReady       Boolean               @default(true)
  // -----------------------------

  startedAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  chatbot          Chatbot               @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  messages         ConversationMessage[]
  leads            Lead[]

  @@index([chatbotId])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' or 'assistant'
  content        String
  sources        Json?        // To track which NDIS document was cited
  createdAt      DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String        @id @default(cuid())
  chatbotId      String
  conversationId String?
  name           String
  email          String?
  phone          String
  status         String        @default("new") // e.g., 'new', 'contacted'
  createdAt      DateTime      @default(now())

  chatbot        Chatbot       @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
}

// -----------------------------------------------------------------------------
// 🛡️ NDIS AUDIT LOG (THE MOAT) 🛡️
// -----------------------------------------------------------------------------

model AuditLog {
  id           String   @id @default(cuid())
  action       String   // e.g. "VIEW_PATIENT_DATA", "CHAT_SESSION_STARTED"
  actorId      String   // Staff member who performed the action
  resourceId   String?  // ID of the accessed resource
  resourceType String?  // e.g., "Conversation", "Document"
  metadata     Json?    // Context specifics
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  actor        User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// FINANCIALS & PRODA INTEGRATION
// -----------------------------------------------------------------------------

// -----------------------------------------------------------------------------
// XERO INTEGRATION
// -----------------------------------------------------------------------------

model XeroToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  tenantId     String
  tenantName   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ClaimStatus {
  DRAFT
  VERIFIED
  EXPORTED
}

model Claim {
  id                       String   @id @default(cuid())
  userId                   String
  participantName          String
  participantNdisNumber    String
  supportItemNumber        String
  supportDeliveredDate     DateTime
  quantityDelivered        Float
  unitPrice                Float
  totalClaimAmount         Float
  status                   ClaimStatus @default(DRAFT)
  updatedBy                String?     // Staff member who verified/modified the claim
  cancellationReason       String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([participantNdisNumber])
  @@index([status])
  @@index([participantNdisNumber, status])  // compound — powers smart-mapping lookups
}
